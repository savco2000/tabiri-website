{
  "name": "tabiri-website",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n CSS,WEB -c cyan,green \"npm:watch:css\" \"npm:serve\"",
    "build:css": "tailwindcss -c tailwind.config.js -i ./src/styles/tailwind.css -o ./assets/css/styles.css --minify",
    "watch:css": "tailwindcss -c tailwind.config.js -i ./src/styles/tailwind.css -o ./assets/css/styles.css --watch",
    "serve": "http-server . -p 8000 -c-1"
  },
  "devDependencies": {
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.10",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.0",
    "http-server": "^14.1.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17"
  }
}
